{
  "name": "orion-design-system",
  "version": "5.1.1",
  "private": true,
  "description": "AI-First Design System - The Chain of Truth",
  "author": "Orion Team",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "docs-site"
  ],
  "scripts": {
    "prepublishOnly": "echo '❌ ERROR: Do not publish the root package. Use npm run release:patch instead.' && exit 1",
    "build": "npm run build:tokens && npm run build:packages && node scripts/enrich-registry-safe.js",
    "build:tokens": "ts-node scripts/generate-types.ts && ts-node scripts/generate-types-dynamic.ts && node scripts/build-tokens.js",
    "build:packages": "turbo run build --filter=@orion-ds/react --filter=@orion-ds/cli --filter=@orion-ds/mcp --filter=@orion-ds/create --filter=@orion-ds/validate",
    "build:react": "npm run build:tokens && turbo run build --filter=@orion-ds/react",
    "build:release": "npm run build:tokens && npm run build:packages && npm run validate:esm && node scripts/enrich-registry-safe.js",
    "build:registry": "npx ts-node --transpile-only scripts/generate-registry.ts && npm run enrich:registry",
    "build:registry-api": "npx ts-node --transpile-only scripts/build-registry-api.ts",
    "build:mcp": "cd packages/mcp && npx tsc",
    "build:cli": "cd packages/cli && npx tsc",
    "build:all": "npm run build && npm run build:registry && npm run build:registry-api",
    "type-check": "turbo run type-check",
    "type-check:react": "cd packages/react && npx tsc --noEmit",
    "type-check:all": "turbo run type-check --force",
    "validate": "node scripts/validate-tokens.js",
    "validate:theme": "node scripts/validate-tokens.js theme.css",
    "validate:code": "node packages/validate/dist/cli.js",
    "validate:spec-yaml": "node scripts/validate-spec-yaml.js",
    "validate:registry-metadata": "node scripts/validate-registry-metadata.js",
    "validate:ai-manifest": "node scripts/validate-ai-manifest.js",
    "validate:esm": "bash scripts/validate-esm.sh",
    "validate:changelog": "node scripts/validate-changelog.js",
    "audit": "npm run validate && npm run type-check && npm run validate:changelog && echo '✅ Full audit passed'",
    "dev": "npx live-server --port=3000 --open=index.html",
    "dev:packages": "turbo run dev --parallel",
    "dev:react": "npm run dev --workspace=@orion/react",
    "prepublish:check": "node scripts/pre-publish-check.js",
    "publish:dry-run": "npm run audit && npm run build && npm run publish:dry-run:packages",
    "publish:dry-run:packages": "cd packages/react && npm publish --dry-run",
    "publish:packages": "cd packages/react && npm publish",
    "version:patch": "npm version patch --workspaces --no-git-tag-version",
    "version:minor": "npm version minor --workspaces --no-git-tag-version",
    "version:major": "npm version major --workspaces --no-git-tag-version",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:dry": "node scripts/release.js patch --dry-run",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,css,md}\"",
    "lint:css": "stylelint \"packages/**/*.css\"",
    "lint:css:fix": "stylelint \"packages/**/*.css\" --fix",
    "create:component": "node scripts/create-component.js",
    "prepare": "husky",
    "sync:manifest": "node scripts/sync-manifest.js",
    "enrich:registry": "node scripts/enrich-registry.js",
    "enrich:registry:safe": "node scripts/enrich-registry-safe.js",
    "audit:visual": "node scripts/audit-visual-consistency.js"
  },
  "keywords": [
    "design-system",
    "ai-first",
    "tokens",
    "css-variables",
    "orion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orion-ds/orion"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "packages/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "orion": {
    "tokenPath": "tokens/",
    "themePath": "theme.css",
    "brands": [
      "orion",
      "unitec",
      "laureate",
      "uvm"
    ],
    "defaultBrand": "orion",
    "defaultTheme": "dark"
  }
}
